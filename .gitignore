# ---------- Data: never commit patient data ----------
# Ignore directory contents but keep the .gitkeep placeholders so the
# layout persists across clones.
data/kaggle_raw/*
data/processed/*
data/external/*
!data/kaggle_raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Signal / dataset binary formats
*.edf
*.edf.gz
*.bdf
*.gdf
*.fif
*.fif.gz
*.set
*.fdt
*.vhdr
*.vmrk
*.eeg
*.cnt
*.nev
*.ns[1-6]
*.h5
*.hdf5
*.nc
*.mat
*.npy
*.npz
*.parquet
*.feather
*.arrow

# Bulk tabular (commit small fixtures explicitly with `git add -f`)
*.csv
*.tsv

# ---------- Model artifacts ----------
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.onnx
*.tflite
checkpoints/
lightning_logs/

# ---------- Experiment tracking ----------
wandb/
.wandb/
mlruns/
outputs/
multirun/
experiments/

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# uv / venv
.venv/
venv/
env/
uv.lock.bak

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------- Secrets ----------
.env
.env.*
!.env.example
*.pem
*.key
kaggle.json

# ---------- OS / Editor ----------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- Logs ----------
*.log
logs/
