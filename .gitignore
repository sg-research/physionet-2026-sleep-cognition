# ---------- Data: never commit patient data ----------
# `data/kaggle_raw` is a symlink to the kagglehub cache populated by
# scripts/download_kaggle_data.py — ignore the symlink itself, not just
# its contents (the `data/kaggle_raw/*` pattern doesn't match a symlink).
data/kaggle_raw
data/kaggle_raw/*

# `data/processed/` and `data/external/` stay as empty directories awaiting
# future data — ignore their contents but keep the .gitkeep placeholders so
# the layout persists across clones.
data/processed/*
data/external/*
!data/processed/.gitkeep
!data/external/.gitkeep

# Signal / dataset binary formats
*.edf
*.edf.gz
*.bdf
*.gdf
*.fif
*.fif.gz
*.set
*.fdt
*.vhdr
*.vmrk
*.eeg
*.cnt
*.nev
*.ns[1-6]
*.h5
*.hdf5
*.nc
*.mat
*.npy
*.npz
*.parquet
*.feather
*.arrow

# Bulk tabular (commit small fixtures explicitly with `git add -f`)
*.csv
*.tsv

# ---------- Model artifacts ----------
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.onnx
*.tflite
checkpoints/
lightning_logs/

